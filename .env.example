# Official OpenAI Platform key. This value is sent only to api.openai.com.
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com
OPENAI_MODEL=gpt-5.6

# Local legacy bridge only. This value is sent only to the one allowlisted MUSE GPT gateway.
# Set OPENAI_BASE_URL=https://api.baizhiyuan.cloud to use it. It is not proof of official
# OpenAI Platform usage; judging deployments should use the official configuration above.
MUSE_GPT_GATEWAY_API_KEY=

# Optional World Labs integration. Both values are required for Forge routes.
WORLDLABS_API_KEY=
INTEGRATION_ADMIN_TOKEN=

PORT=4175
HOST=127.0.0.1
