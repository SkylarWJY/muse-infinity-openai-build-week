# Credential for live GPT-5.6 reasoning. Official Platform credentials also enable
# OpenAI Realtime and speech fallback; the authorized compatible gateway is reasoning-only.
OPENAI_API_KEY=
# Optional, exact allowlist only: https://api.openai.com or https://api.baizhiyuan.cloud.
# Any other value is rejected back to the official origin rather than used as a provider.
OPENAI_BASE_URL=https://api.openai.com
# Optional, exact allowlist only: gpt-5.6 or gpt-5.6-sol.
OPENAI_MODEL=gpt-5.6

# Optional MiniMax T2A key for the role-cast narration. It never handles reasoning.
MINIMAX_API_KEY=

# Optional World Labs integration. Both values are required for Forge routes.
WORLDLABS_API_KEY=
INTEGRATION_ADMIN_TOKEN=

PORT=4175
HOST=127.0.0.1
